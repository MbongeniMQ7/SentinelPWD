# Sample env file. Copy to `.env.local` and fill in values for your environment.

# WebSocket URL for the fatigue alert transport. Used by the admin/owner
# clients to receive worker alerts in real time and (optionally) by worker
# clients to forward their own alerts to other connected sessions.
#
# Leave blank or remove to disable the WebSocket transport entirely; the app
# will keep working with in-memory alerts only.
#
# Examples:
#   VITE_FATIGUE_WS_URL=ws://localhost:8080/fatigue
#   VITE_FATIGUE_WS_URL=wss://api.your-domain.com/fatigue
VITE_FATIGUE_WS_URL=
